{
  "headers": [
    {
      "source": "/v2/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/v2/(.*)/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v2/sms-cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/v2/billing?action=monthly-sweep",
      "schedule": "0 6 1 * *"
    }
  ],
  "functions": {
    "api/v2/generate-theme.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/v2/chat.js": {
      "maxDuration": 120
    },
    "api/v2/prompt-test.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/v2/billing.js": {
      "maxDuration": 60
    },
    "api/v2/sms.js": {
      "maxDuration": 30
    },
    "api/v2/sms-cron.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/v2/stripe-webhook",
      "destination": "/api/v2/billing?action=webhook"
    },
    {
      "source": "/api/v2/clicksend-webhook",
      "destination": "/api/v2/sms-webhook"
    },
    {
      "source": "/v2/event/:slug",
      "destination": "/api/v2/event-page?slug=:slug"
    },
    {
      "source": "/v2/cohost",
      "destination": "/v2/cohost/index.html"
    }
  ]
}
