{
  "headers": [
    {
      "source": "/v2/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/admin-panel/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/create/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/dashboard/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/login/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/profile/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/contacts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/cohost/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/preview/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/v2/review/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v2/sms-cron",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "api/v2/generate-theme.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/v2/chat.js": {
      "maxDuration": 120
    },
    "api/v2/prompt-test.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/v2/billing.js": {
      "maxDuration": 60
    },
    "api/v2/sms.js": {
      "maxDuration": 30
    },
    "api/v2/sms-cron.js": {
      "maxDuration": 60
    },
    "api/v2/blog.js": {
      "maxDuration": 60
    },
    "api/v2/admin-alert.js": {
      "maxDuration": 30
    },
    "api/v2/user-notification.js": {
      "maxDuration": 30
    },
    "api/v2/render-video.js": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "redirects": [
    {
      "source": "/pricing",
      "destination": "/v2/pricing/",
      "permanent": true
    },
    {
      "source": "/pricing/",
      "destination": "/v2/pricing/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/v2/sitemap"
    },
    {
      "source": "/api/v2/stripe-webhook",
      "destination": "/api/v2/billing?action=webhook"
    },
    {
      "source": "/api/v2/clicksend-webhook",
      "destination": "/api/v2/sms-webhook"
    },
    {
      "source": "/v2/event/:slug/photos",
      "destination": "/v2/photos/index.html"
    },
    {
      "source": "/v2/event/:slug",
      "destination": "/api/v2/event-page?slug=:slug"
    },
    {
      "source": "/v2/cohost",
      "destination": "/v2/cohost/index.html"
    },
    {
      "source": "/blog/feed.xml",
      "destination": "/api/v2/blog?action=rss"
    },
    {
      "source": "/blog/category/:category",
      "destination": "/api/v2/blog-page?type=category&slug=:category"
    },
    {
      "source": "/blog/tag/:tag",
      "destination": "/api/v2/blog-page?type=tag&slug=:tag"
    },
    {
      "source": "/blog/author/:author",
      "destination": "/api/v2/blog-page?type=author&slug=:author"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/v2/blog-page?slug=:slug"
    },
    {
      "source": "/inspiration",
      "destination": "/v2/inspiration/index.html"
    },
    {
      "source": "/inspiration/",
      "destination": "/v2/inspiration/index.html"
    },
    {
      "source": "/inspiration/:type",
      "destination": "/v2/inspiration/index.html"
    },
    {
      "source": "/inspiration/:type/",
      "destination": "/v2/inspiration/index.html"
    }
  ]
}
